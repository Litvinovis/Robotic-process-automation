SUB(VKPersonalLikesUAE)
   WAITMS(RND(1001, 1200))
   LCLICK(45,172)
   WAITMS(RND(3001, 3200))
   LCLICK(546,302)
   WAITMS(RND(3001, 3200))
   LCLICK(821,301)
   WAITMS(RND(3001, 3200))		// заходим в группу
   $var = 0
   WHILE($var < 8)
      INC($var,1)
      WHEELDOWN
      WAITMS(500)
      WHEELDOWN
      WAITMS(500)
      WHEELDOWN
      WAITMS(500)
      WHEELDOWN
      WAITMS(500)
      WHEELDOWN
      WAITMS(500)
      WHEELDOWN
      WAITMS(500)				// прокрутка экрана
      GETSCREEN()
      IF_PIXEL_IN (638,152, 685, 1034, 12959160)
      LCLICK($_return1, $_return2)
      END_IF
      WAITMS(RND(1001, 1200))	// анализ экрана + поставить лайк
   END_CYC
END_SUB

SUB(VKscroll)
   WAITMS(RND(2001, 2200))
   WHEELDOWN
   WAITMS(500)
   WHEELDOWN
   WAITMS(500)
   WHEELDOWN
   WAITMS(500)
   WHEELDOWN
   WAITMS(500)
   WHEELDOWN
   WAITMS(500)					// прокрутка экрана
   LCLICK(1100,210)
   WAITMS(RND(1001, 1200))
END_SUB

SUB(IGSubscribe)
   $var = 0
   WHILE($var < 15)
      INC($var,1)
      WAITMS(RND(2001, 2200))
      GETSCREEN(1120, 211, 1257, 1005)
      IF_PIXEL_IN (1120, 211, 1257, 1005, 16160000)
         LCLICK($_return1, $_return2)
      WAITMS(RND(1001, 1200))
      END_IF
   END_CYC         // Подписка
END_SUB

SUB(IGScroll)
   $var = 0
   WHILE($var < 10)
      INC($var,1)
      WHEELDOWN
      WAITMS(RND(1001, 1200))
   END_CYC        // прокрутка
END_SUB

