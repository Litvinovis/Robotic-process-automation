SUB(FBFriendsAdd)
   LCLICK(156,296)  // начало добавления в друзья
   WAITMS(RND(1350, 1600))
   $var = 0
   WHILE($var < 40)
      INC($var,1)
      WHEELDOWN
      WAITMS(RND(350, 600))
      GETSCREEN(10, 247, 336, 1028)
      WAITMS(RND(350, 600))
      IF_PIXEL_IN (10, 247, 336, 1028, 15890200)
         LCLICK($_return1, $_return2)
      END_IF
   END_CYC         // конец добавления в друзья
END_SUB

